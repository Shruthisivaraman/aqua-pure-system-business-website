# ==========================================
# AQUA PURE SYSTEM - Environment Variables
# Copy this file to .env and fill in your actual values
# ==========================================

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# For local development:
# MONGO_URI=mongodb://localhost:27017/aqua-pure-system

# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aqua-pure-system?retryWrites=true&w=majority

MONGO_URI=mongodb://localhost:27017/aqua-pure-system

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://localhost:8000

# ==========================================
# ADMIN AUTHENTICATION
# ==========================================
# Change this to a strong, random string in production
ADMIN_SECRET=your_strong_admin_secret_here

# ==========================================
# TWILIO WhatsApp CONFIGURATION
# Get credentials from https://www.twilio.com/console
# ==========================================

# Your Twilio Account SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp Number (provided by Twilio)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Admin WhatsApp Number to receive notifications
# Format: whatsapp:+[country_code][phone_number]
ADMIN_WHATSAPP_NUMBER=whatsapp:+919962647678

# ==========================================
# EMAIL CONFIGURATION (Optional for future use)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@aquapuresystem.com

# ==========================================
# JWT CONFIGURATION (Optional for future use)
# ==========================================
# JWT_SECRET=your_jwt_secret_key_here
# JWT_EXPIRE=7d

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_NAME=AQUA PURE SYSTEM
APP_DESCRIPTION=Water Filter Installation & Maintenance Services

# Max file upload size in bytes (default: 5MB = 5242880)
MAX_FILE_SIZE=5242880

# ==========================================
# LOGGING
# ==========================================
# Log level options: error, warn, info, debug
LOG_LEVEL=info
